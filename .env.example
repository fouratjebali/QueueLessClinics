# Trello Board Setup Configuration
# Copy this file to .env and fill in your Trello API credentials

# Your Trello API Key (from https://trello.com/app-key)
TRELLO_KEY=your_api_key_here

# Your Trello API Token (from https://trello.com/app-key)
TRELLO_TOKEN=your_api_token_here

# Your Trello Board ID (from board URL: https://trello.com/b/BOARD_ID/...)
BOARD_ID=your_board_id_here
